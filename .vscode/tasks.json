{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Course Setup",
      "type": "shell",
      "command": "bash -c ${input:courseCommand}",
      "options": {
        "cwd": "/workspaces/Solace_Academy_SAM_Dev_Demo/acme-retail/scripts"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Simulate Events",
      "type": "shell",
      "command": "bash ./run-scenario.sh ${input:eventScenario}",
      "options": {
        "cwd": "/workspaces/Solace_Academy_SAM_Dev_Demo/acme-retail/scripts"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "Submit My Work",
      "type": "shell",
      "command": "/workspaces/Solace_Academy_SAM_Dev_Demo/300-Agents/sam/.venv/bin/python3 evaluate_project.py",
      "options": {
        "cwd": "/workspaces/Solace_Academy_SAM_Dev_Demo/acme-retail/grading/tests"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true,
        "focus": true
      }
    }
  ],
  "inputs": [
    {
      "id": "courseCommand",
      "type": "pickString",
      "description": "Which course do you want to set up?",
      "options": [
        {
          "label": "200 - Orchestration",
          "value": "'source ./200-setup.sh /workspaces/Solace_Academy_SAM_Dev_Demo/200-Orchestration'"
        },
        {
          "label": "300 - Agents",
          "value": "'source ./300-setup.sh /workspaces/Solace_Academy_SAM_Dev_Demo/300-Agents'"
        },
        {
          "label": "400 - Evals",
          "value": "'source ./400-setup.sh /workspaces/Solace_Academy_SAM_Dev_Demo/400-Evals'"
        },
        {
          "label": "500 - Tooling & Plugins",
          "value": "'source ./600-setup.sh /workspaces/Solace_Academy_SAM_Dev_Demo/600-Tooling-Plugins'"
        },
        {
          "label": "600 - Troubleshooting",
          "value": "'source ./700-setup.sh /workspaces/Solace_Academy_SAM_Dev_Demo/700-Troubleshooting'"
        },
        {
          "label": "700 - System Design",
          "value": "'source ./800-setup.sh /workspaces/Solace_Academy_SAM_Dev_Demo/800-System-Design'"
        }
      ]
    },
    {
      "id": "eventScenario",
      "type": "pickString",
      "description": "Which Acme Retail scenario do you want to simulate?",
      "options": [
        {
          "label": "1️⃣ Knowledge Query",
          "value": "--test-knowledge-query"
        },
        {
          "label": "2️⃣ Order Fulfillment",
          "value": "--test-order-fulfillment"
        },
        {
          "label": "3️⃣ Inventory Management",
          "value": "--test-inventory-management"
        },
        {
          "label": "4️⃣ Incident Response",
          "value": "--test-incident-response"
        },
        {
          "label": "5️⃣ Logistics Management",
          "value": "--test-logistics"
        }
      ]
    }
  ]
}